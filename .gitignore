# ROS 2 colcon build outputs
build/
install/
log/

# Stray colcon outputs accidentally created inside packages
src/*/build/
src/*/install/
src/*/log/

# Python cache / bytecode / coverage
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Backup files
*.bak
*.orig
*.backup

# rosbag / large binaries (workspace-local data)
*.bag
*.mcap
*.mp4

# Workspace-local config (사용자별 절대 경로 / DSN 들어감 — 공유 금지).
# 패키지 안의 sample 은 정상 추적; 워크스페이스 root 의 인스턴스만 제외.
